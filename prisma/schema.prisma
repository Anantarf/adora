generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model homebase {
  id          String    @id @default(cuid())
  name        String    @unique
  address     String
  phone       String?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  groups             group[]
  events             event[]
  preferredByPlayers player[] @relation("PreferredHomebase")

  @@map("Homebase")
}
model account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model attendance {
  id        String            @id @default(cuid())
  date      DateTime
  status    attendance_status
  note      String?           @db.Text
  playerId  String
  eventId   String?
  createdAt DateTime          @default(now())

  player    player            @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "Attendance_playerId_fkey")
  event     event?            @relation(fields: [eventId], references: [id], onDelete: SetNull, map: "Attendance_eventId_fkey")

  @@unique([playerId, date], map: "Attendance_playerId_date_key")
  @@index([eventId], map: "Attendance_eventId_idx")
}

model auditlog {
  id          String   @id @default(cuid())
  action      String
  targetTable String
  recordId    String?
  details     Json?    // Added to store what actually changed, added, or deleted
  timestamp   DateTime @default(now())
  userId      String?
  user        user?    @relation(fields: [userId], references: [id], map: "AuditLog_userId_fkey")

  @@index([userId], map: "AuditLog_userId_fkey")
  @@index([timestamp])
}

model certificate {
  id         String   @id @default(cuid())
  title      String
  fileUrl    String
  uploadedAt DateTime @default(now())
  playerId   String?
  groupId    String?
  group      group?   @relation(fields: [groupId], references: [id], onDelete: Cascade, map: "Certificate_groupId_fkey")
  player     player?  @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "Certificate_playerId_fkey")

  @@index([groupId], map: "Certificate_groupId_fkey")
  @@index([playerId], map: "Certificate_playerId_fkey")
}

model event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  date        DateTime
  type        String    @default("LATIHAN")
  location    String?
  homebaseId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  eventGroups eventGroup[]
  homebase    homebase? @relation(fields: [homebaseId], references: [id], onDelete: SetNull, map: "Event_homebaseId_fkey")
  attendances attendance[]

  @@index([homebaseId], map: "Event_homebaseId_idx")
  @@index([date], map: "Event_date_idx")
  @@map("Event")
}

model eventGroup {
  id      String @id @default(cuid())
  eventId String
  groupId String

  event   event  @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventGroup_eventId_fkey")
  group   group  @relation(fields: [groupId], references: [id], onDelete: Cascade, map: "EventGroup_groupId_fkey")

  @@unique([eventId, groupId], map: "EventGroup_eventId_groupId_key")
  @@index([eventId], map: "EventGroup_eventId_idx")
  @@index([groupId], map: "EventGroup_groupId_idx")
  @@map("EventGroup")
}

model group {
  id          String        @id @default(cuid())
  name        String        @unique(map: "Group_name_key")
  description String?       @db.Text
  homebaseId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  homebase    homebase?     @relation(fields: [homebaseId], references: [id], onDelete: SetNull, map: "Group_homebaseId_fkey")
  certificate certificate[]
  eventGroups eventGroup[]
  player      player[]

  @@index([homebaseId], map: "Group_homebaseId_idx")
  @@map("Group")
}

model player {
  id                  String        @id @default(cuid())
  name                String
  dateOfBirth         DateTime
  placeOfBirth        String?
  gender              String?
  weight              String?
  height              String?
  schoolOrigin        String?
  address             String?
  email               String?
  phoneNumber         String?
  medicalHistory      String?       @db.Text
  parentName          String?
  parentAddress       String?
  parentPhoneNumber   String?
  photoUrl            String?
  isDeleted           Boolean       @default(false)
  groupId             String?
  parentId            String?
  preferred_homebaseId String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  attendance          attendance[]
  certificate         certificate[]
  group               group?        @relation(fields: [groupId], references: [id], onDelete: SetNull, map: "Player_groupId_fkey")
  user                user?         @relation(fields: [parentId], references: [id], onDelete: SetNull, map: "Player_parentId_fkey")
  preferred_homebase  homebase?     @relation("PreferredHomebase", fields: [preferred_homebaseId], references: [id], onDelete: SetNull, map: "Player_preferred_homebaseId_fkey")
  statistic           statistic[]

  @@index([groupId], map: "Player_groupId_idx")
  @@index([parentId], map: "Player_parentId_idx")
  @@index([preferred_homebaseId], map: "Player_preferred_homebaseId_idx")
  @@unique([name, dateOfBirth, groupId], map: "Player_name_dateOfBirth_groupId_key")
  @@map("Player")
}

model session {
  id           String   @id @default(cuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
}

model evaluationPeriod {
  id        String      @id @default(cuid())
  name      String      // e.g. "Semester 1 2025"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean     @default(false)
  createdAt DateTime    @default(now())

  statistic statistic[]

  @@map("EvaluationPeriod")
}

model statistic {
  id          String    @id @default(cuid())
  date        DateTime
  metricsJson String    @db.LongText
  status      String    @default("Draft")
  playerId    String
  periodId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  player      player             @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "Statistic_playerId_fkey")
  period      evaluationPeriod?  @relation(fields: [periodId], references: [id], onDelete: SetNull, map: "Statistic_periodId_fkey")
  history     statisticHistory[]

  @@unique([playerId, periodId], map: "Statistic_playerId_periodId_key")
  @@index([status])
  @@index([periodId], map: "Statistic_periodId_idx")
}

model statisticHistory {
  id          String    @id @default(cuid())
  statisticId String
  metricsJson String    @db.LongText
  status      String
  editedAt    DateTime  @default(now())
  editedBy    String?

  statistic   statistic @relation(fields: [statisticId], references: [id], onDelete: Cascade, map: "StatisticHistory_statisticId_fkey")
  user        user?     @relation(fields: [editedBy], references: [id], onDelete: SetNull, map: "StatisticHistory_editedBy_fkey")

  @@index([statisticId], map: "StatisticHistory_statisticId_idx")
  @@map("StatisticHistory")
}

model user {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique(map: "User_email_key")
  emailVerified DateTime?
  image         String?
  username      String?    @unique(map: "User_username_key")
  password      String?
  role          user_role  @default(PARENT)
  isDeleted     Boolean    @default(false)
  account          account[]
  auditlog         auditlog[]
  player           player[]
  session          session[]
  statisticHistory statisticHistory[]
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
}

enum attendance_status {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum user_role {
  ADMIN
  PARENT
}
